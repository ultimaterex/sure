<div class="space-y-4">
  <div class="prose prose-sm text-secondary">
    <p class="text-primary font-medium"><%= t("wise_items.panel.setup_instructions") %></p>
    <ol>
      <li><%= t("wise_items.panel.step_1") %></li>
      <li><%= t("wise_items.panel.step_2") %></li>
      <li><%= t("wise_items.panel.step_3") %></li>
    </ol>

    <p class="text-primary font-medium"><%= t("wise_items.panel.field_descriptions") %></p>
    <ul>
      <li><strong><%= t("wise_items.panel.fields.api_token.label") %>:</strong> <%= t("wise_items.panel.fields.api_token.description") %> <%= t("wise_items.panel.required") %></li>
      <li><strong><%= t("wise_items.panel.fields.base_url.label") %>:</strong> <%= t("wise_items.panel.fields.base_url.description") %></li>
    </ul>
  </div>

  <% error_msg = local_assigns[:error_message] || @error_message %>
  <% if error_msg.present? %>
    <div class="p-2 rounded-md bg-destructive/10 text-destructive text-sm overflow-hidden">
      <p class="line-clamp-3" title="<%= error_msg %>"><%= error_msg %></p>
    </div>
  <% end %>

  <%
    # Get or initialize a wise_item for this family
    # - If family has an item WITH credentials, use it (for updates)
    # - If family has an item WITHOUT credentials, use it (to add credentials)
    # - If family has no items at all, create a new one
    wise_item = Current.family.wise_items.first_or_initialize(name: "Wise Connection")
    is_new_record = wise_item.new_record?
  %>

  <%= styled_form_with model: wise_item,
                       url: is_new_record ? wise_items_path : wise_item_path(wise_item),
                       scope: :wise_item,
                       method: is_new_record ? :post : :patch,
                       data: { turbo: true },
                       class: "space-y-3" do |form| %>
    <%= form.text_field :api_token,
                        label: t("wise_items.panel.fields.api_token.label"),
                        placeholder: is_new_record ? t("wise_items.panel.fields.api_token.placeholder_new") : t("wise_items.panel.fields.api_token.placeholder_update"),
                        type: :password %>

    <%= form.text_field :base_url,
                        label: t("wise_items.panel.fields.base_url.label"),
                        placeholder: is_new_record ? t("wise_items.panel.fields.base_url.placeholder_new") : t("wise_items.panel.fields.base_url.placeholder_update"),
                        value: wise_item.base_url %>

    <div class="flex justify-end">
      <%= form.submit is_new_record ? t("wise_items.panel.save_button") : t("wise_items.panel.update_button"),
                      class: "inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-medium btn btn--primary" %>
    </div>
  <% end %>

  <% items = local_assigns[:wise_items] || @wise_items || Current.family.wise_items.where.not(api_token: [nil, ""]) %>
  <div class="flex items-center gap-2">
    <% if items&.any? %>
      <div class="w-2 h-2 bg-success rounded-full"></div>
      <p class="text-sm text-secondary"><%= t("wise_items.panel.status_configured_html", accounts_path: accounts_path).html_safe %></p>
    <% else %>
      <div class="w-2 h-2 bg-gray-400 rounded-full"></div>
      <p class="text-sm text-secondary"><%= t("wise_items.panel.status_not_configured") %></p>
    <% end %>
  </div>
</div>
